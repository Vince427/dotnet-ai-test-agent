# LLM Configuration
# Copy this file to .env and fill in your values
# .env is ignored by git

LLM_ENDPOINT=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-key-here
LLM_MODEL=anthropic/claude-3.5-sonnet:beta

# Optional: vision-capable model for the V3 Tier-2 `--vision` fallback (multimodal).
# Falls back to LLM_MODEL if unset. Use a model that accepts images.
# VISION_MODEL=anthropic/claude-3.5-sonnet:beta

# For LiteLLM local proxy:
# LLM_ENDPOINT=http://localhost:4000
# LLM_API_KEY=sk-1234
# LLM_MODEL=gpt-4o-mini
